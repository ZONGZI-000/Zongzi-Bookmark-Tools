{
  "manifest_version": 3,
  "name": "粽子书签工具",
  "version": "1.0.0",
  "description": "同步、备份和清理浏览器书签。",
  "permissions": [
    "bookmarks",
    "storage",
    "unlimitedStorage",
    "alarms",
    "notifications",
    "downloads",
    "tabs",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "粽子书签工具",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "models/mini_embeddings.bin",
        "models/local-summary/*",
        "lib/transformers.min.js",
        "offscreen-inference.html",
        "offscreen-inference.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
